# Relay Zero attributes. LFS is intentionally opt-in only; do not add broad
# binary globs without a documented asset need and review.

*                       text=auto eol=lf

[attr]unity-json        text eol=lf linguist-language=json
[attr]unity-yaml        text merge=unityyamlmerge eol=lf linguist-language=yaml

# C# and shader sources.
*.cs                    text diff=csharp
*.csproj                text eol=lf
*.sln                   text eol=crlf
*.props                 text eol=lf
*.targets               text eol=lf
*.cginc                 text
*.compute               text linguist-language=hlsl
*.hlsl                  text linguist-language=hlsl
*.raytrace              text linguist-language=hlsl
*.shader                text

# Unity JSON files.
*.asmdef                unity-json
*.asmref                unity-json
*.index                 unity-json
*.inputactions          unity-json
*.shadergraph           unity-json
*.shadersubgraph        unity-json

# Unity UI Toolkit files.
*.tss                   text diff=css linguist-language=css
*.uss                   text diff=css linguist-language=css
*.uxml                  text linguist-language=xml linguist-detectable

# Unity YAML files.
*.anim                  unity-yaml
*.asset                 unity-yaml
*.brush                 unity-yaml
*.controller            unity-yaml
*.flare                 unity-yaml
*.fontsettings          unity-yaml
*.giparams              unity-yaml
*.guiskin               unity-yaml
*.lighting              unity-yaml
*.mask                  unity-yaml
*.mat                   unity-yaml
*.meta                  unity-yaml
*.mixer                 unity-yaml
*.overrideController    unity-yaml
*.playable              unity-yaml
*.prefab                unity-yaml
*.preset                unity-yaml
*.renderTexture         unity-yaml
*.scenetemplate         unity-yaml
*.shadervariants        unity-yaml
*.signal                unity-yaml
*.spriteatlas           unity-yaml
*.spriteatlasv2         unity-yaml
*.terrainlayer          unity-yaml
*.unity                 unity-yaml
*.physicMaterial        unity-yaml
*.physicsMaterial2D     unity-yaml

# Generated or noisy dependency areas.
Unity/Assets/Plugins/**             linguist-generated
Unity/Packages/packages-lock.json   linguist-generated

# Binary assets remain ordinary Git blobs until a later documented LFS change.
*.aif                   binary
*.aiff                  binary
*.apk                   binary
*.app                   binary
*.bmp                   binary
*.cubemap               binary
*.dll                   binary
*.exe                   binary
*.fbx                   binary
*.FBX                   binary
*.gif                   binary
*.jpg                   binary
*.jpeg                  binary
*.mp3                   binary
*.ogg                   binary
*.otf                   binary
*.pdf                   binary
*.png                   binary
*.psd                   binary
*.so                    binary
*.ttf                   binary
*.unitypackage          binary
*.wav                   binary
*.webp                  binary
