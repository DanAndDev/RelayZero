# Relay Zero local deployment example.
# Copy to .env locally if needed. Do not commit real secrets.

ASPNETCORE_ENVIRONMENT=Development
RELAYZERO_CONTROL_PLANE_URL=http://localhost:5080
RELAYZERO_REDIS_CONNECTION=localhost:6379
RELAYZERO_GAME_SERVER_EXECUTABLE=../Unity/Builds/Server/RelayZeroServer.exe
