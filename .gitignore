# Relay Zero monorepo ignore rules.

# Unity generated state. The Unity project root is /Unity, but keep the root
# patterns too so local caches from the initial project bootstrap stay ignored.
.utmp/
# Accidental Unity-project folders at the monorepo root. The real Unity project
# lives under /Unity.
/[Aa]ssets/
/[Pp]ackages/
/[Pp]roject[Ss]ettings/
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Pp]rofiler[Cc]aptures/
/[Mm]emory[Cc]aptures/
/[Rr]ecordings/
/Unity/[Ll]ibrary/
/Unity/[Tt]emp/
/Unity/[Oo]bj/
/Unity/[Bb]uild/
/Unity/[Bb]uilds/
/Unity/[Ll]ogs/
/Unity/[Uu]ser[Ss]ettings/
/Unity/[Pp]rofiler[Cc]aptures/
/Unity/[Mm]emory[Cc]aptures/
/Unity/[Rr]ecordings/

# Unity, IDE, and crash generated files.
*.log
*.blend1
*.blend1.meta
*.DotSettings.user
.vs/
.gradle/
ExportedObj/
.consulo/
/*.csproj
/*.sln
/Unity/*.csproj
/Unity/*.sln
*.unityproj
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.pidb.meta
*.pdb.meta
*.mdb.meta
sysinfo.txt
mono_crash.*
crashlytics-build.properties

# Build/package outputs.
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app
/artifacts/
/TestResults/
/Builds/
/Unity/Builds/

# Unity plugin and generated asset data.
/Unity/[Aa]ssets/Plugins/Editor/JetBrains*
/Unity/ServerData
/Unity/[Aa]ssets/StreamingAssets/aa*
/Unity/[Aa]ssets/AddressableAssetsData/link.xml*
/Unity/[Aa]ssets/Addressables_Temp*
/Unity/[Aa]ssets/AddressableAssetsData/*/*.bin*
/Unity/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/Unity/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
/Unity/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
/Unity/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta
/Unity/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*
# Regenerated by RelayZero.Editor.Build.BuildInfoGenerator so commit/dirty state stays current.
/Unity/Assets/RelayZero/Runtime/Foundation/BuildInfo.Generated.cs
/Unity/Assets/RelayZero/Runtime/Foundation/BuildInfo.Generated.cs.meta

# Backend outputs and local machine state.
/Backend/**/bin/
/Backend/**/obj/
/Backend/**/TestResults/
/Backend/**/coverage/
/Backend/.vs/

# Local secrets and machine-specific configuration. Commit only *.example files.
.env
.env.*
!.env.example
!*.env.example
appsettings.Development.json
appsettings.Local.json
*.local.json

# Package/cache folders.
.npm-cache/
.nuget/
